{
  "name": "claude-cloud-agent",
  "version": "2.0.0",
  "private": true,
  "description": "Claude Cloud Agent — Full autonomous AI command center with dashboard, multi-model routing, MCP, and Obsidian AI brain",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:backend": "turbo dev --filter=@claude-agent/backend",
    "dev:dashboard": "turbo dev --filter=@claude-agent/dashboard",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "start": "npm run start --workspace=apps/backend",
    "setup-google": "npm run setup-google --workspace=apps/backend"
  },
  "devDependencies": {
    "turbo": "^2.3.0"
  },
  "keywords": ["claude", "ai", "agent", "autonomous", "mcp", "dashboard", "obsidian"],
  "license": "MIT",
  "packageManager": "npm@10.0.0"
}
