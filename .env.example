# ─────────────────────────────────────────────
# Anthropic (Required)
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────
# Google OAuth2 (Required — covers all Google tools)
# Get from: https://console.cloud.google.com/
#   1. Create a project
#   2. Enable APIs: Gmail, Calendar, Drive, Cloud Resource Manager,
#      IAM, Cloud Build, Cloud Run, Cloud Storage, Service Usage, Admin SDK
#   3. Create OAuth2 credentials → Desktop app
#   4. Copy Client ID and Secret below
#
# First-time setup:      npm run setup-google
# Add a second account:  npm run setup-google -- --account work
# Tokens saved to:       data/google-tokens-<account>.json  (gitignored)
# ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=urn:ietf:wg:oauth:2.0:oob

# ─────────────────────────────────────────────
# Google Cloud Platform (Optional defaults)
# GCP_DEFAULT_PROJECT_ID is used when no projectId is given in a gcp_* tool call.
# ─────────────────────────────────────────────
# GCP_DEFAULT_PROJECT_ID=my-project-123

# ─────────────────────────────────────────────
# Google Workspace Admin SDK (Optional)
# Required to use admin_* tools (manage users, groups, org units).
# The authenticated OAuth account must be a Super Admin or delegated admin.
# GOOGLE_ADMIN_CUSTOMER_ID: found at admin.google.com → Account → Settings (e.g. C0xxxxxxx)
# GOOGLE_ADMIN_DOMAIN: your primary Workspace domain (e.g. example.com)
# ─────────────────────────────────────────────
# GOOGLE_ADMIN_CUSTOMER_ID=C0xxxxxxx
# GOOGLE_ADMIN_DOMAIN=example.com

# ─────────────────────────────────────────────
# Twilio SMS (Required — active by default)
# Get from: https://console.twilio.com/
# ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─────────────────────────────────────────────
# Telegram (Optional — uncomment TelegramChannel in src/index.ts)
# Get token from @BotFather on Telegram
# ─────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=

# ─────────────────────────────────────────────
# Slack (Optional — uncomment SlackChannel in src/index.ts)
# Get from: https://api.slack.com/apps
# ─────────────────────────────────────────────
# SLACK_BOT_TOKEN=
# SLACK_SIGNING_SECRET=

# ─────────────────────────────────────────────
# WhatsApp via Twilio (Optional — uncomment WhatsAppChannel in src/index.ts)
# Uses same Twilio credentials above, just needs a WhatsApp-enabled number
# ─────────────────────────────────────────────
# TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ─────────────────────────────────────────────
# Zoom (Optional — uncomment ZoomToolModule in src/index.ts)
# Get from: https://marketplace.zoom.us/ — create a Server-to-Server OAuth app
# ─────────────────────────────────────────────
# ZOOM_ACCOUNT_ID=
# ZOOM_CLIENT_ID=
# ZOOM_CLIENT_SECRET=

# ─────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────
PORT=3000
